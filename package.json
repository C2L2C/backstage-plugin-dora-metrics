{
  "name": "@c2l2c/backstage-plugin-dora-metrics",
  "version": "0.3.3",
  "description": "A Backstage frontend plugin that displays DORA metrics (Deployment Frequency, Lead Time, Change Failure Rate, MTTR) for catalog entities via the GitHub API.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "backstage": {
    "role": "frontend-plugin",
    "configSchema": "config.d.ts"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.esm.js" },
    "./alpha": { "types": "./dist/alpha.d.ts", "default": "./dist/alpha.esm.js" },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "config.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "backstage-cli package build",
    "start": "backstage-cli package start",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "yarn build"
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "dora",
    "dora-metrics",
    "devops",
    "github",
    "deployment-frequency",
    "lead-time",
    "change-failure-rate",
    "mttr"
  ],
  "homepage": "https://github.com/C2L2C/backstage-plugin-dora-metrics#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/C2L2C/backstage-plugin-dora-metrics.git"
  },
  "bugs": {
    "url": "https://github.com/C2L2C/backstage-plugin-dora-metrics/issues"
  },
  "author": "C2L2C",
  "license": "Apache-2.0",
  "dependencies": {
    "@backstage/catalog-model": "^1.7.6",
    "@backstage/config": "^1.3.2",
    "@backstage/core-components": "^0.18.7",
    "@backstage/core-plugin-api": "^1.12.3",
    "@backstage/frontend-plugin-api": "^0.15.1",
    "@backstage/plugin-catalog-react": "^2.0.0",
    "@material-ui/core": "^4.12.4",
    "@radix-ui/react-select": "^2.2.6",
    "lucide-react": "^1.7.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/cli-defaults": "^0.1.0",
    "@types/react": "^18",
    "jest": "^30",
    "jest-environment-jsdom": "^30"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
