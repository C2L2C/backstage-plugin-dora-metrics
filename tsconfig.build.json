{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-types/src",
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
